<UserControl x:Class="StudentsHelper.UserControls.ScheduleUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:StudentsHelper.UserControls"
             xmlns:vm="clr-namespace:StudentsHelper.ViewModel"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <vm:ScheduleVM x:Key="ScheduleVM"/>
    </UserControl.Resources>
    
    <Grid DataContext="{StaticResource ScheduleVM}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>

        <UniformGrid Grid.Row="0" Rows="1">
            <Button Command="{Binding GetScheduleCommand}" IsEnabled="{Binding IsGetScheduleButtonEnabled}">Pobierz plan zajęć</Button>
            <Button Command="{Binding ShowScheduleInstructionWindowCommand}">Instrukcja</Button>
        </UniformGrid>

        <Grid Grid.Row="1">
            <WebBrowser x:Name="ScheduleWebBrowser"></WebBrowser>
        </Grid>
        
    </Grid>
</UserControl>
