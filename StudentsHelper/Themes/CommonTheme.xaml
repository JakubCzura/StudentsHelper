<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="ApplicationBackground" Color="White"></SolidColorBrush>
    
    <Style TargetType="DataGrid" x:Key="UserPanelDataGrid">
        <Setter Property="FontSize" Value="16"></Setter>
    </Style>

    <Style TargetType="Window" x:Key="WindowStyle">
        <Setter Property="Background" Value="{StaticResource ApplicationBackground}"></Setter>
        <Setter Property="Title" Value="StudentsHelper"></Setter>
        <Setter Property="Height" Value="450"></Setter>
        <Setter Property="Width" Value="800"></Setter>
    </Style>

    <Style TargetType="UserControl" x:Key="UserControlStyle">
        <Setter Property="Background" Value="{StaticResource ApplicationBackground}"></Setter>
    </Style>

    <Style TargetType="UniformGrid" x:Key="SettingsUnifromGridStyle">
        <Setter Property="Background" Value="{StaticResource ApplicationBackground}"></Setter>
    </Style>
</ResourceDictionary>